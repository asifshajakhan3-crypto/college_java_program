class Solution {
    public int lengthOfLastWord(String s) {
        int length = 0;
        
        // Loop backwards through the string
        for (int i = s.length() - 1; i >= 0; i--) {
            if (s.charAt(i) != ' ') {
                length++;
            } else {
                // If we already found characters and hit a space, the last word is complete
                if (length > 0) {
                    return length;
                }
            }
        }
        
        return length;
    }
}
