class ParkingSystem {
    // In Java, we declare the array with [] after the type or variable name, 
    // and initialize it using the 'new' keyword.
    private int[] slots;

    public ParkingSystem(int big, int medium, int small) {
        slots = new int[] {big, medium, small};
    }
    
    public boolean addCar(int carType) {
        // carType 1, 2, 3 maps to index 0, 1, 2
        if (slots[carType - 1] > 0) {
            slots[carType - 1]--;
            return true;
        }
        return false;
    }
}

