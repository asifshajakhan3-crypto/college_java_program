class Solution {
    public boolean isAnagram(String s, String t) {
        // If lengths don't match, they cannot be anagrams
        if (s.length() != t.length()) {
            return false;
        }
        
        // Frequency array for lowercase English letters (26)
        int[] count = new int[26];
        
        // Populate frequencies using the first string, and decrement using the second
        for (int i = 0; i < s.length(); i++) {
            count[s.charAt(i) - 'a']++;
            count[t.charAt(i) - 'a']--;
        }
        
        // If all counts are zero, they are valid anagrams
        for (int val : count) {
            if (val != 0) {
                return false;
            }
        }
        
        return true;
    }
}
