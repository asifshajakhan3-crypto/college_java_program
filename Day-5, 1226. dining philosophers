import java.util.concurrent.locks.ReentrantLock;

class DiningPhilosophers {

    // Create a lock array representing the 5 forks
    private final ReentrantLock[] forks = new ReentrantLock[5];

    public DiningPhilosophers() {
        for (int i = 0; i < 5; i++) {
            forks[i] = new ReentrantLock();
        }
    }

    // call the run(...) methods of any runnable to execute its code
    public void wantsToEat(int philosopher,
                           Runnable pickLeftFork,
                           Runnable pickRightFork,
                           Runnable eat,
                           Runnable putLeftFork,
                           Runnable putRightFork) throws InterruptedException {

        int leftFork = philosopher;
        int rightFork = (philosopher + 1) % 5;

        // Resource Hierarchy / Asymmetric Lock Acquisition Strategy
        if (philosopher % 2 == 0) {
            // Even philosophers: Left then Right
            forks[leftFork].lock();
            forks[rightFork].lock();
        } else {
            // Odd philosophers: Right then Left
            forks[rightFork].lock();
            forks[leftFork].lock();
        }

        try {
            // Perform actions
            pickLeftFork.run();
            pickRightFork.run();
            eat.run();
            putLeftFork.run();
            putRightFork.run();
        } finally {
            // Release both locks in reverse or order
            forks[leftFork].unlock();
            forks[rightFork].unlock();
        }
    }
}
