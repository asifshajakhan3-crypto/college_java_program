import java.util.concurrent.Semaphore;

class FooBar {
    private int n;
    // Semaphore for foo starts with 1 permit so it can execute first
    private Semaphore fooSem = new Semaphore(1);
    // Semaphore for bar starts with 0 permits so it must wait
    private Semaphore barSem = new Semaphore(0);

    public FooBar(int n) {
        this.n = n;
    }

    public void foo(Runnable printFoo) throws InterruptedException {
        for (int i = 0; i < n; i++) {
            fooSem.acquire(); // Decrements permit to 0, blocking subsequent foo calls
            // printFoo.run() outputs "foo". Do not change or remove this line.
            printFoo.run();
            barSem.release(); // Increments bar permit to 1, waking up the bar thread
        }
    }

    public void bar(Runnable printBar) throws InterruptedException {
        for (int i = 0; i < n; i++) {
            barSem.acquire(); // Blocks until foo releases barSem
            // printBar.run() outputs "bar". Do not change or remove this line.
            printBar.run();
            fooSem.release(); // Increments foo permit to 1, waking up the foo thread
        }
    }
}
