class Solution {
    public boolean isPalindrome(int x) {
        // Negative numbers and numbers ending in 0 (except 0 itself) are not palindromes
        if (x < 0 || (x % 10 == 0 && x != 0)) {
            return false;
        }

        int rev = 0;
        while (x > rev) {
            rev = rev * 10 + x % 10;
            x /= 10;
        }

        // True if x equals rev (even number of digits) 
        // or x equals rev/10 (odd number of digits, discarding the middle digit)
        return x == rev || x == rev / 10;
    }
}
